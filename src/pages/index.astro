---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';

const projects = [
  {
    title: 'Dicero Guides',
    description: 'Comprehensive guides and strategies for popular dice games.',
    href: '/diceroguides',
    link: 'https://diceroguides.com',
  },
  {
    title: 'Is Claude Nerfed?',
    description: 'Check if Claude is currently in peak-hour limits in your timezone.',
    href: '/is-claude-nerfed',
    link: 'https://is-claude-nerfed.com',
  },
  {
    title: 'SBIT Avatar',
    description: 'An avatar generator focused on SBIT-inspired personality styling.',
    href: '/sbit-avatar',
    link: 'https://sbitavatar.com',
  },
  {
    title: 'Scritchy Scratchy',
    description: 'A super-satisfying scratch card idle game with auto-scratching and massive jackpots.',
    href: '/scritchy-scratchy',
    link: 'https://scritchyscratchy.online',
  },
  {
    title: 'Hytale Tools',
    description: 'An all-in-one data powerhouse for the Hytale community.',
    href: '/hytaletools',
    link: 'https://hytaletools.io',
  },
  {
    title: 'Kingdom of Marionettes Online',
    description: 'A website about the game Kingdom of Marionettes, with link to online demo.',
    href: '/kingdom-of-marionettes',
    link: 'https://kingdomofmarionettes.online',
  },
  {
    title: 'Zombies and Luig',
    description: 'A website about the game Zombies and Luig, with itch.io game and tips.',
    href: '/zombies-and-luig',
    link: 'https://zombiesandluig.com',
  },
  {
    title: 'Arrow Puzzle Escape',
    description: 'A logic puzzle game where you must remove arrows in the correct order to escape.',
    href: '/arrows-puzzle-escape',
    link: 'https://arrowspuzzleescape.com',
  },
];
---

<Layout
  title="Lazy Software Developer"
  description="Hi there, I'm a Lazy Software Developer"
>
  <Header />
  <main class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <section class="mb-12">
      <h1 class="text-3xl font-bold text-[#24292f] mb-4">
        Hi there, I'm a Lazy Software Developer
      </h1>
      <p class="text-[#57606a] text-lg leading-relaxed">
        They say "pick a lazy person to do a hard job because they will find an easy way to do it." That's me. I build tools so I can spend more time doing... well, nothing.
      </p>
    </section>

    <section>
      <h2 class="text-xl font-semibold text-[#24292f] mb-6">What I'm Building</h2>
      <div class="space-y-4">
        {projects.map((project) => (
          <div class="block p-4 border border-[#d0d7de] rounded-lg hover:border-[#0969da] hover:bg-[#f6f8fa] transition-all">
            <div class="flex items-center justify-between">
              <a href={project.href} class="flex-1">
                <h3 class="font-semibold text-[#24292f]">{project.title}</h3>
                <p class="text-sm text-[#57606a] mt-1">{project.description}</p>
              </a>
              <a
                href={project.link}
                target="_blank"
                rel="noopener noreferrer"
                class="text-[#0969da] text-sm hover:underline whitespace-nowrap"
              >
                Visit →
              </a>
            </div>
          </div>
        ))}
      </div>
    </section>
  </main>

  <footer class="border-t border-[#d0d7de] mt-12">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex items-center justify-between">
      <p class="text-[#57606a] text-sm">
        © {new Date().getFullYear()} Lazy Software Developer
      </p>
      <div class="flex items-center gap-3">
        <a
          href="https://github.com/lazysoftwaredeveloper"
          target="_blank"
          rel="noopener noreferrer"
          class="text-[#57606a] hover:text-[#24292f] transition-colors"
          aria-label="GitHub"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.167 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
          </svg>
        </a>
        <a
          href="https://www.youtube.com/@lazysoftwaredeveloper"
          target="_blank"
          rel="noopener noreferrer"
          class="text-[#57606a] hover:text-[#FF0000] transition-colors"
          aria-label="YouTube"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
        </a>
      </div>
    </div>
  </footer>
</Layout>
