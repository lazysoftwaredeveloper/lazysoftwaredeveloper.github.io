---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';

const projectLink = 'https://sbitavatar.com';
const projectName = 'SBIT Avatar';
---

<Layout
  title="SBIT Avatar - Lazy Software Developer"
  description="An avatar generator focused on SBIT-inspired personality styling."
>
  <Header />
  <main class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <a href="/" class="text-sm text-[#57606a] hover:text-[#0969da] mb-8 inline-flex items-center">
      <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Back
    </a>

    <article>
      <header class="mb-8">
        <h1 class="text-3xl font-bold text-[#24292f] mb-4">SBIT Avatar</h1>
        <p class="text-lg text-[#57606a] leading-relaxed mb-6">
          A focused avatar generator that turns SBIT personality style into a distinct visual identity.
        </p>
        <a
          href={projectLink}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center px-4 py-2 bg-[#0969da] text-white text-sm font-medium rounded-md hover:bg-[#085bb8] transition-colors"
        >
          Visit {projectName}
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </header>

      <div class="border-t border-[#d0d7de] pt-8">
        <section class="mb-8">
          <h2 class="text-xl font-semibold text-[#24292f] mb-3">What It Does</h2>
          <ul class="space-y-2 text-[#57606a]">
            <li class="flex items-start">
              <span class="text-[#0969da] mr-2">•</span>
              Generates avatars around an SBIT-inspired personality aesthetic
            </li>
            <li class="flex items-start">
              <span class="text-[#0969da] mr-2">•</span>
              Helps translate a mood, persona, or character vibe into a profile image
            </li>
            <li class="flex items-start">
              <span class="text-[#0969da] mr-2">•</span>
              Works well for social profiles, experiments, and lightweight personal branding
            </li>
            <li class="flex items-start">
              <span class="text-[#0969da] mr-2">•</span>
              Keeps the experience focused on one recognizable style instead of a generic avatar builder
            </li>
          </ul>
        </section>
      </div>
    </article>
  </main>

  <footer class="border-t border-[#d0d7de] mt-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex items-center justify-between">
      <p class="text-[#57606a] text-sm">
        © {new Date().getFullYear()} Lazy Software Developer
      </p>
      <a
        href="https://github.com/lazysoftwaredeveloper"
        target="_blank"
        rel="noopener noreferrer"
        class="text-[#57606a] hover:text-[#24292f] transition-colors"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.167 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
        </svg>
      </a>
    </div>
  </footer>
</Layout>
